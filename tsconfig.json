{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "esModuleInterop": true,

    "sourceMap": true,

    "strict": true,

    "noUncheckedIndexedAccess": true,

    "isolatedModules": true,

    "noUncheckedSideEffectImports": true,

    "moduleDetection": "force",

    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
